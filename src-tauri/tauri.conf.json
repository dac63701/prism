{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Prism",
  "version": "0.2.1",
  "identifier": "com.dac63.prism",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["prism"]
      }
    }
  },
  "app": {
    "windows": [
      {
        "title": "Prism",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["$HOME/Videos/Prism/**", "$HOME/Videos/**", "$HOME/Movies/Prism/**", "$HOME/Movies/**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "wix": null,
      "nsis": null
    }
  }
}
